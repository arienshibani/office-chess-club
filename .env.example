MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/chess-club?retryWrites=true&w=majority
MONGODB_DB_NAME=chess-club
SLACK_CLIENT_ID=your_slack_client_id
# PKCE sign-in does not use client_secret on token exchange (see Slack "Using PKCE" docs).
# Optional if ORIGIN is set — callback is always {ORIGIN}/auth/callback/slack
SLACK_REDIRECT_URI=http://localhost:5173/auth/callback/slack
# PKCE is always used (required once enabled in Slack; one-way setting).
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SESSION_SECRET=a-long-random-secret-string-at-least-32-chars
ORIGIN=http://localhost:5173
